# =============================================================================
# Restaurante La Zíngara — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# IMPORTANT — build vs runtime:
#   Nuxt reads `.env` at BUILD time (dev/build/generate) but NOT at production runtime.
#   On the VPS, `scripts/deploy.sh` sources this `.env` before `pnpm build` AND before
#   `pm2 start ecosystem.config.cjs`, so the vars reach both the build and the Node process.
#   (If you build/run manually, you must `set -a; . ./.env; set +a` first.)
#
# IMPORTANT — Node version:
#   Production (VPS, pm2) requires Node >= 22. @supabase/ssr's createServerClient throws
#   "Node.js 20 detected without native WebSocket support" on Node <22 (WebSocket is not
#   a global there), which 500s every SSR route via a plugin cascade. scripts/deploy.sh
#   pins nvm to Node 22 and refuses to deploy on older versions. VPS setup:
#       nvm install 22 && nvm alias default 22 && npm i -g pnpm@10 pm2
#
# Var names follow Nuxt's runtimeConfig convention: NUXT_ prefix + UPPER_SNAKE_CASE
# (a camelCase key like `smsProvider` -> `NUXT_SMS_PROVIDER`). See nuxt.config.ts.
# =============================================================================

# ---- Supabase (@nuxtjs/supabase) ----
# Client (public) + server. SUPABASE_SERVICE_ROLE_KEY is server-only (never in client bundle).
# Without these the server plugin throws at boot -> Pinia never inits -> every SSR route 500s.
NUXT_PUBLIC_SUPABASE_URL=https://sqtzcjcyciatagakmmcf.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Auth cookie Secure flag: set to 'false' if accessing via HTTP-only VPS (no HTTPS).
# Default is true (requires HTTPS). Read at build time from process.env.
# NUXT_PUBLIC_SUPABASE_COOKIE_SECURE=false

# ---- LabsMobile SMS (runtimeConfig: smsProvider, labsMobile*) ----
# Provider selection: mock (dev, verify code "1234") | labsmobile (prod).
# Maps to runtimeConfig.smsProvider.
NUXT_SMS_PROVIDER=mock
# Credentials (only needed when NUXT_SMS_PROVIDER=labsmobile). Basic HTTP auth:
# username = your LabsMobile account email, token = API token from LabsMobile settings.
NUXT_LABS_MOBILE_USERNAME=your_email@example.com
NUXT_LABS_MOBILE_TOKEN=your_api_token
NUXT_LABS_MOBILE_SENDER=LaZingara
# Test mode: 1 = simulated (no real SMS, no credit deducted); 0 = real send.
NUXT_LABS_MOBILE_TEST=1

# ---- CORS (runtimeConfig.corsAllowedOrigins) ----
# Comma-separated whitelist of allowed origins. Origin must match exactly (scheme, host, port).
# Default in nuxt.config.ts covers localhost:3000 + production domain.
# Override at deploy: export NUXT_CORS_ALLOWED_ORIGINS=http://57.131.33.90:3000,https://www.lazingara.es
NUXT_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://www.lazingara.es

# ---- App (runtimeConfig.public) ----
NUXT_PUBLIC_SITE_URL=https://www.lazingara.es
