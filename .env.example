# =============================================================================
# Restaurante La Zíngara — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# ---- Supabase (@nuxtjs/supabase) ----
# The module auto-reads NUXT_PUBLIC_SUPABASE_URL and NUXT_PUBLIC_SUPABASE_KEY
# for the client. SUPABASE_SERVICE_ROLE_KEY is server-only (never client bundle).
NUXT_PUBLIC_SUPABASE_URL=https://sqtzcjcyciatagakmmcf.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- LabsMobile SMS API ----
# Provider: mock (development, code "1234") | labsmobile (production)
SMS_PROVIDER=mock
# Auth: Basic HTTP with username (email) + tokenapi (generated in LabsMobile settings)
LABSMOBILE_USERNAME=your_email@example.com
LABSMOBILE_TOKEN=your_api_token
LABSMOBILE_SENDER=LaZingara
# Test mode: 1 = simulated (no real SMS, no credit deducted); 0 = real send
LABSMOBILE_TEST=1

# ---- App ----
NUXT_PUBLIC_SITE_URL=https://www.lazingara.es
